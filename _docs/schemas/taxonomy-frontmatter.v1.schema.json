{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://geodocs.dev/schemas/taxonomy-frontmatter.v1.schema.json",
  "title": "Geodocs Taxonomy Frontmatter v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "title",
    "slug",
    "description",
    "L1_Journey",
    "L2_Role",
    "L3_Artifact",
    "artifact_type",
    "primary_role",
    "journey_stage"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 3
    },
    "slug": {
      "type": "string",
      "pattern": "^/docs/[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "L1_Journey": {
      "type": "string",
      "enum": [
        "Fundamentals",
        "Strategy",
        "Execution",
        "Proof",
        "Operations"
      ]
    },
    "L2_Role": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "SEO Specialist",
          "Marketing Manager",
          "Developer",
          "Content Creator",
          "AI Agent"
        ]
      },
      "uniqueItems": true
    },
    "L3_Artifact": {
      "type": "string",
      "enum": [
        "Checklist",
        "Template",
        "Script",
        "Matrix",
        "SOP",
        "Brief",
        "Comparison"
      ]
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "Checklist",
        "Template",
        "Script",
        "Matrix",
        "SOP",
        "Brief",
        "Comparison"
      ]
    },
    "primary_role": {
      "type": "string",
      "enum": [
        "SEO Specialist",
        "Marketing Manager",
        "Developer",
        "Content Creator",
        "AI Agent"
      ]
    },
    "journey_stage": {
      "type": "string",
      "enum": [
        "Fundamentals",
        "Strategy",
        "Execution",
        "Proof",
        "Operations"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "draft",
        "review",
        "deprecated"
      ]
    },
    "version": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "intent_stage": {
      "type": "string",
      "enum": [
        "understand",
        "plan",
        "execute",
        "prove",
        "operate"
      ]
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3,
      "uniqueItems": true
    },
    "llm": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "intent": {
          "type": "string"
        },
        "index_priority": {
          "type": "string",
          "enum": [
            "low",
            "normal",
            "high"
          ]
        },
        "canonical_topic": {
          "type": "string"
        },
        "related_topics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
